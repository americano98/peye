{
  "name": "peye",
  "version": "0.1.0",
  "description": "Standalone CLI for visual diffing UI screenshots against Figma references.",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "bin": {
    "peye": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf coverage dist test-output peye-output",
    "dev": "tsx src/cli/bin.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "pnpm check",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "keywords": [
    "cli",
    "visual-diff",
    "figma",
    "playwright",
    "pixelmatch"
  ],
  "homepage": "https://github.com/americano98/peye#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/americano98/peye.git"
  },
  "bugs": {
    "url": "https://github.com/americano98/peye/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "commander": "^14.0.3",
    "pixelmatch": "7.1.0",
    "playwright": "1.58.2",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^22.19.15",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vitest": "^4.1.0"
  }
}
