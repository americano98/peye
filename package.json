{
  "name": "@americano98/peye",
  "version": "0.2.5",
  "description": "Standalone CLI for visual diffing UI screenshots against Figma references.",
  "keywords": [
    "cli",
    "figma",
    "pixelmatch",
    "playwright",
    "visual-diff"
  ],
  "homepage": "https://github.com/americano98/peye#readme",
  "bugs": {
    "url": "https://github.com/americano98/peye/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/americano98/peye.git"
  },
  "bin": {
    "peye": "dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf coverage dist test-output peye-output",
    "dev": "tsx src/cli/bin.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "prepack": "pnpm check",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "commander": "^14.0.3",
    "pixelmatch": "7.1.0",
    "playwright": "1.58.2",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "0.17.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.11.0"
}
